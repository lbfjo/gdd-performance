rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /athletes/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name','pin','active'])
                    && request.resource.data.name is string
                    && request.resource.data.pin is string
                    && request.resource.data.active is bool;
      allow update: if request.resource.data.name is string;
      allow delete: if false;
    }

    match /checkins/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['athleteId','athleteName','date','timestamp'])
                    && request.resource.data.athleteId is string
                    && request.resource.data.date is string;
      allow update: if false;
      allow delete: if resource.data.athleteId is string;
    }

    match /config/{doc} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly([
                     'staffPin','weeklyTarget','nutritionAppointmentsEnabled'
                   ])
                   && request.resource.data.staffPin is string;
    }

    match /nutrition_logs/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['athleteId','athleteName','date','weight','timestamp'])
                    && request.resource.data.athleteId is string
                    && request.resource.data.date is string
                    && request.resource.data.weight is number;
      allow update: if request.resource.data.weight is number;
    }

    match /nutrition_slots/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll([
                      'date','time','status','athleteId','athleteName','createdAt','bookedAt'
                    ])
                    && request.resource.data.date is string
                    && request.resource.data.time is string
                    && request.resource.data.status == 'available';
      allow update: if request.resource.data.status in ['available','booked'];
      allow delete: if resource.data.status == 'available';
    }

    match /bookings/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['athleteId','athleteName','date','slot','bookedAt'])
                    && request.resource.data.athleteId is string
                    && request.resource.data.date is string
                    && request.resource.data.slot in ['morning','lunch','evening'];
      allow update, delete: if false;
    }
  }
}
